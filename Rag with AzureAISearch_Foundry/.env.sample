# ============================================================
# MODEL PROVIDER — set to "openai" or "foundry"
# Where: choose based on your deployment choice
# ============================================================
MODEL_PROVIDER=foundry

# Enable/disable skillset (embeddings + vector search)
# Where: set by preference in this repo
ENABLE_SKILLS=true

# ============================================================
# Azure AI Search
# ============================================================
# Where: Azure portal -> your Search service -> Overview (endpoint)
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net

# Where: Azure portal -> your Search service -> Keys (admin key)
AZURE_SEARCH_ADMIN_KEY=<search-admin-key>

# Optional (only if you use a user-assigned identity on the Search service)
# Where: Azure portal -> Managed Identity -> user-assigned identity resource ID
AZURE_SEARCH_USER_ASSIGNED_IDENTITY_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.ManagedIdentity/userAssignedIdentities/<identity>

# ============================================================
# TWO INDEXES — one per blob container
# Where: choose your own index names and blob container names
# ============================================================
INDEX_1_NAME=<index-name-1>
CONTAINER_1_NAME=<blob-container-1>

INDEX_2_NAME=<index-name-2>
CONTAINER_2_NAME=<blob-container-2>

# ============================================================
# Azure Blob Storage
# ============================================================
# Choose ONE auth mode:
#   connection_string OR managed_identity
AZURE_STORAGE_AUTH_MODE=managed_identity

# If connection_string auth:
# Where: Storage account -> Access keys -> Connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net

# If managed identity auth:
# Where: Storage account -> Properties -> Resource ID
AZURE_STORAGE_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Storage/storageAccounts/<account>

# ============================================================
# OPTION A: Azure OpenAI (used when MODEL_PROVIDER=openai)
# ============================================================
# Where: Azure OpenAI resource -> Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<openai-key>

# Where: Azure OpenAI resource -> Deployments
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=<embedding-deployment-name>
AZURE_OPENAI_EMBEDDING_MODEL_NAME=<embedding-model-name>
AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536
AZURE_OPENAI_CHAT_DEPLOYMENT=<chat-deployment-name>

# ============================================================
# OPTION B: Azure AI Foundry (used when MODEL_PROVIDER=foundry)
#
# Authentication: Entra ID (DefaultAzureCredential)
# Run `az login` before running the pipeline.
# ============================================================
# Where: Foundry project -> Project settings / endpoint
AZURE_FOUNDRY_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>

# Where: Azure OpenAI resource -> Keys and Endpoint (OpenAI-compatible endpoint)
AZURE_FOUNDRY_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/

# Where: Foundry -> Deployments
AZURE_FOUNDRY_API_VERSION=2024-10-21
AZURE_FOUNDRY_EMBEDDING_DEPLOYMENT=<embedding-deployment-name>
AZURE_FOUNDRY_EMBEDDING_MODEL_NAME=<embedding-model-name>
AZURE_FOUNDRY_EMBEDDING_DIMENSIONS=1536
AZURE_FOUNDRY_CHAT_DEPLOYMENT=<chat-deployment-name>
